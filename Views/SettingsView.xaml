<UserControl x:Class="TaskNote.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TaskNote.Views"
             mc:Ignorable="d"
             d:DesignHeight="420" d:DesignWidth="320">

    <Border Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="0"
            Width="320"
            VerticalAlignment="Top"
            Effect="{StaticResource FloatingShadow}">

        <StackPanel>

            <!-- â”€â”€ Header â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <Grid Margin="20,16,16,16">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource AccentColor}"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Settings"
                               FontFamily="{StaticResource MainFont}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button HorizontalAlignment="Right"
                        Style="{StaticResource IconButton}"
                        Padding="7,6"
                        Command="{Binding DataContext.ToggleSettingsCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}">
                    <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"
                          Fill="{DynamicResource TextSecondary}"
                          Stretch="Uniform" Width="11" Height="11"/>
                </Button>
            </Grid>

            <!-- Divider -->
            <Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,0"/>

            <!-- â”€â”€ Content â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <StackPanel Margin="20,18,20,20">

                <!-- Database section -->
                <TextBlock Text="DATABASE"
                           FontFamily="{StaticResource MainFont}"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Storage location for your task data. Point to a cloud-synced folder for multi-device access."
                           FontFamily="{StaticResource MainFont}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           LineHeight="16"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding DatabasePath, Mode=OneWay}"
                             Style="{StaticResource MinimalTextBox}"
                             IsReadOnly="True"
                             Margin="0,0,8,0"
                             FontSize="11"
                             ToolTip="{Binding DatabasePath}"/>
                    <Button Grid.Column="1"
                            Content="Browse"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseDatabasePathCommand}"/>
                </Grid>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,18"/>

                <!-- Audio alerts section -->
                <TextBlock Text="AUDIO ALERTS"
                           FontFamily="{StaticResource MainFont}"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="0,0,0,14"/>

                <!-- Start sound -->
                <TextBlock Text="Timer Start"
                           FontFamily="{StaticResource MainFont}"
                           FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding StartSoundPath, Mode=OneWay}"
                             Style="{StaticResource MinimalTextBox}"
                             IsReadOnly="True" FontSize="11"
                             Margin="0,0,6,0"
                             ToolTip="{Binding StartSoundPath}"/>
                    <Button Grid.Column="1" Content="Browse"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,4,0"
                            Command="{Binding BrowseStartSoundCommand}"/>
                    <Button Grid.Column="2"
                            Style="{StaticResource DangerIconButton}"
                            Padding="8,6"
                            Command="{Binding ClearStartSoundCommand}">
                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"
                              Fill="{DynamicResource DangerColor}"
                              Stretch="Uniform" Width="9" Height="9"/>
                    </Button>
                </Grid>

                <!-- Complete sound -->
                <TextBlock Text="Timer Complete"
                           FontFamily="{StaticResource MainFont}"
                           FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding FinishSoundPath, Mode=OneWay}"
                             Style="{StaticResource MinimalTextBox}"
                             IsReadOnly="True" FontSize="11"
                             Margin="0,0,6,0"
                             ToolTip="{Binding FinishSoundPath}"/>
                    <Button Grid.Column="1" Content="Browse"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,4,0"
                            Command="{Binding BrowseFinishSoundCommand}"/>
                    <Button Grid.Column="2"
                            Style="{DynamicResource DangerIconButton}"
                            Padding="8,6"
                            Command="{Binding ClearFinishSoundCommand}">
                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"
                              Fill="{DynamicResource DangerColor}"
                              Stretch="Uniform" Width="9" Height="9"/>
                    </Button>
                </Grid>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,18,0,18"/>

                <!-- Appearance Section -->
                <TextBlock Text="APPEARANCE"
                           FontFamily="{DynamicResource MainFont}"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Dark Theme Mode"
                               FontFamily="{DynamicResource MainFont}"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"/>
                               
                    <ToggleButton Grid.Column="1"
                                  IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                                  VerticalAlignment="Center">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="BackgroundBorder"
                                        Width="40" Height="22"
                                        CornerRadius="11"
                                        Background="#3E3E3C"
                                        BorderThickness="1"
                                        BorderBrush="Transparent">
                                    <Ellipse x:Name="ThumbEllipse"
                                             Width="16" Height="16"
                                             Fill="White"
                                             HorizontalAlignment="Left"
                                             Margin="2,0,2,0">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform X="0" Y="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter TargetName="BackgroundBorder" Property="Background" Value="#E5E5E0"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource AccentColor}"/>
                                        <Setter TargetName="ThumbEllipse" Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform X="18" Y="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="{DynamicResource BorderColorHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

