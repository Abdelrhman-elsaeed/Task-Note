<UserControl x:Class="TaskNote.Views.BoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TaskNote.Views"
             xmlns:vm="clr-namespace:TaskNote.ViewModels"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             xmlns:res="clr-namespace:TaskNote.Resources"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Column drag adorner: floating card with title + task count -->
        <DataTemplate x:Key="ColumnDragAdorner">
            <Border Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1.5"
                    CornerRadius="10"
                    Padding="14,10"
                    Effect="{StaticResource FloatingShadow}"
                    Opacity="0.96"
                    MinWidth="200">
                <StackPanel Orientation="Horizontal">
                    <!-- grip dots -->
                    <Grid Margin="0,0,10,0" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Row="0" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource AccentColor}" Margin="1"/>
                        <Ellipse Grid.Row="0" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource AccentColor}" Margin="1"/>
                        <Ellipse Grid.Row="1" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource AccentColor}" Margin="1"/>
                        <Ellipse Grid.Row="1" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource AccentColor}" Margin="1"/>
                        <Ellipse Grid.Row="2" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource AccentColor}" Margin="1"/>
                        <Ellipse Grid.Row="2" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource AccentColor}" Margin="1"/>
                    </Grid>
                    <TextBlock Text="{Binding Name}"
                               FontFamily="{StaticResource MainFont}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Task drag adorner -->
        <DataTemplate x:Key="TaskDragAdorner">
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12,9"
                    Effect="{StaticResource FloatingShadow}"
                    Opacity="0.95"
                    MaxWidth="260">
                <TextBlock Text="{Binding Name}"
                           FontFamily="{StaticResource MainFont}"
                           FontSize="13"
                           Foreground="{DynamicResource TextPrimary}"
                           TextWrapping="Wrap"
                           MaxWidth="230"/>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- â”€â”€ Board Header â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <Border BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource AppBackground}"
                Cursor="Arrow"
                Padding="24,15,24,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center"
                            Visibility="{Binding HasProject, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" x:Name="ProjectNameDisplay"
                                   Text="{Binding ProjectName}"
                                   FontFamily="{StaticResource MainFont}"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Cursor="IBeam"
                                   MouseLeftButtonDown="ProjectNameDisplay_MouseLeftButtonDown"
                                   ToolTip="Double-click to rename"
                                   Visibility="{Binding IsProjectNameEditing, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}"/>

                        <TextBox Grid.Column="0" x:Name="ProjectNameEdit"
                                 Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{StaticResource MainFont}"
                                 FontSize="17" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimary}"
                                 VerticalAlignment="Center"
                                 Padding="4,2"
                                 BorderBrush="{DynamicResource AccentColor}"
                                 BorderThickness="1"
                                 Background="{DynamicResource CardBackground}"
                                 CaretBrush="{DynamicResource AccentColor}"
                                 KeyDown="ProjectNameEdit_KeyDown"
                                 LostFocus="ProjectNameEdit_LostFocus"
                                 IsVisibleChanged="ProjectNameEdit_IsVisibleChanged"
                                 Visibility="{Binding IsProjectNameEditing, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Button Grid.Column="1" Style="{StaticResource IconButton}" Padding="5" Margin="6,0,0,0"
                                Cursor="Hand"
                                Command="{Binding StartRenamingProjectCommand}"
                                ToolTip="Rename project"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsProjectNameEditing, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}">
                            <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.996.996 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                  Fill="{DynamicResource TextTertiary}"
                                  Stretch="Uniform" Width="13" Height="13"/>
                        </Button>
                    </Grid>
                    <TextBlock Text="{Binding ProjectTargetDate, StringFormat={}{0:dddd, MMM d, yyyy}}"
                               FontFamily="{StaticResource MainFont}"
                               FontSize="11" FontWeight="Medium"
                               Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center"
                               Margin="0,2,0,0"
                               Cursor="Arrow"/>
                </StackPanel>

                <TextBlock Grid.Column="0" Text="Kanban Board"
                           FontFamily="{StaticResource MainFont}"
                           FontSize="17" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           Cursor="Arrow">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasProject}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button Grid.Column="1" Content="+ Add Column"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding AddColumnCommand}"/>
            </Grid>
        </Border>

        <!-- â”€â”€ Columns Horizontal Scroll â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Style="{StaticResource MinimalScrollViewer}"
                      Background="Transparent"
                      Padding="24,20,24,20">

            <ListBox ItemsSource="{Binding Columns}"
                     dd:DragDrop.IsDragSource="True"
                     dd:DragDrop.IsDropTarget="True"
                     dd:DragDrop.DropHandler="{Binding}"
                     dd:DragDrop.DragHandler="{Binding}"
                     dd:DragDrop.UseDefaultDragAdorner="False"
                     dd:DragDrop.DragAdornerTemplate="{StaticResource ColumnDragAdorner}"
                     dd:DragDrop.UseDefaultEffectDataTemplate="True"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     VerticalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background"   Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"      Value="0"/>
                        <Setter Property="Margin"       Value="0"/>
                        <Setter Property="Focusable"    Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <!-- â•”â•â• COLUMN TEMPLATE â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•— -->
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ColumnBorder"
                                Width="285"
                                Margin="0,0,18,0"
                                Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="12"
                                VerticalAlignment="Top"
                                MinHeight="120"
                                Effect="{StaticResource SubtleShadow}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- header -->
                                    <RowDefinition Height="*"/>     <!-- tasks -->
                                    <RowDefinition Height="Auto"/>  <!-- footer -->
                                </Grid.RowDefinitions>

                                <!-- â”€â”€ Column Header â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
                                <Border Grid.Row="0"
                                        Padding="6,10,10,10"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>  <!-- drag grip -->
                                            <ColumnDefinition Width="*"/>     <!-- title -->
                                            <ColumnDefinition Width="Auto"/>  <!-- actions -->
                                        </Grid.ColumnDefinitions>

                                        <!-- â ¿ Drag handle â€” grab here to move the whole column -->
                                        <Border x:Name="DragHandle"
                                                Grid.Column="0"
                                                Padding="6,4"
                                                CornerRadius="6"
                                                Cursor="SizeAll"
                                                Background="Transparent"
                                                ToolTip="Drag to reorder column">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/><ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Row="0" Grid.Column="0" x:Name="D1" Width="3" Height="3" Fill="{DynamicResource TextTertiary}" Margin="1.5"/>
                                                <Ellipse Grid.Row="0" Grid.Column="1" x:Name="D2" Width="3" Height="3" Fill="{DynamicResource TextTertiary}" Margin="1.5"/>
                                                <Ellipse Grid.Row="1" Grid.Column="0" x:Name="D3" Width="3" Height="3" Fill="{DynamicResource TextTertiary}" Margin="1.5"/>
                                                <Ellipse Grid.Row="1" Grid.Column="1" x:Name="D4" Width="3" Height="3" Fill="{DynamicResource TextTertiary}" Margin="1.5"/>
                                                <Ellipse Grid.Row="2" Grid.Column="0" x:Name="D5" Width="3" Height="3" Fill="{DynamicResource TextTertiary}" Margin="1.5"/>
                                                <Ellipse Grid.Row="2" Grid.Column="1" x:Name="D6" Width="3" Height="3" Fill="{DynamicResource TextTertiary}" Margin="1.5"/>
                                            </Grid>
                                        </Border>

                                        <!-- Column title (double-click to rename) -->
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                 res:FocusBehavior.IsFocused="{Binding IsFocused, Mode=TwoWay}"
                                                 Style="{StaticResource SeamlessTextBox}"
                                                 FontFamily="{StaticResource MainFont}"
                                                 FontSize="14" FontWeight="SemiBold"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 VerticalAlignment="Center"
                                                 Margin="2,0,6,0"
                                                 MaxLength="50"
                                                 dd:DragDrop.DragSourceIgnore="True"/>

                                        <!-- Color + Delete actions -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource IconButton}"
                                                    Padding="5" Margin="0,0,2,0"
                                                    Command="{Binding ChangeColorCommand}"
                                                    ToolTip="Change column color">
                                                <Ellipse Width="10" Height="10"
                                                         Fill="{DynamicResource AccentColor}"/>
                                            </Button>
                                            <Button Style="{StaticResource DangerIconButton}"
                                                    Padding="5"
                                                    Command="{Binding DeleteCommand}"
                                                    ToolTip="Delete column">
                                                <Path Data="M0 0 L8 8 M8 0 L0 8"
                                                      Stroke="{DynamicResource DangerColor}"
                                                      StrokeThickness="1.5"
                                                      Stretch="Uniform" Width="8" Height="8"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- â”€â”€ Tasks List â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Style="{StaticResource MinimalScrollViewer}"
                                              Margin="8,8,8,0">

                                    <Grid>
                                        <!-- Empty state placeholder -->
                                        <Border Margin="0,4,0,4"
                                                Padding="12,20"
                                                CornerRadius="8"
                                                BorderThickness="1.5"
                                                Visibility="{Binding Tasks.Count, Converter={StaticResource ZeroCountToVisibilityConverter}}">
                                            <Border.Background>
                                                <SolidColorBrush Color="#F5F5F2" Opacity="0.6"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <DrawingBrush Viewport="0,0,8,8" ViewportUnits="Absolute" TileMode="Tile">
                                                    <DrawingBrush.Drawing>
                                                        <GeometryDrawing Brush="Transparent">
                                                            <GeometryDrawing.Pen>
                                                                <Pen Brush="{DynamicResource BorderColor}" Thickness="1.5" DashStyle="{x:Static DashStyles.Dash}"/>
                                                            </GeometryDrawing.Pen>
                                                            <GeometryDrawing.Geometry>
                                                                <RectangleGeometry Rect="0.75,0.75,6.5,6.5"/>
                                                            </GeometryDrawing.Geometry>
                                                        </GeometryDrawing>
                                                    </DrawingBrush.Drawing>
                                                </DrawingBrush>
                                            </Border.BorderBrush>
                                            <TextBlock Text="Drop tasks here"
                                                       FontFamily="{StaticResource MainFont}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextTertiary}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>

                                        <!-- Tasks -->
                                        <ListBox ItemsSource="{Binding Tasks}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                 dd:DragDrop.IsDragSource="True"
                                                 dd:DragDrop.IsDropTarget="True"
                                                 dd:DragDrop.DropHandler="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 dd:DragDrop.DragHandler="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 dd:DragDrop.UseDefaultDragAdorner="False"
                                                 dd:DragDrop.DragAdornerTemplate="{StaticResource TaskDragAdorner}">

                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Background"              Value="Transparent"/>
                                                    <Setter Property="BorderThickness"         Value="0"/>
                                                    <Setter Property="Padding"                 Value="0"/>
                                                    <Setter Property="Margin"                  Value="0"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>

                                            <!-- â•”â•â• TASK CARD TEMPLATE â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•— -->
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="TaskCard"
                                                            Style="{StaticResource CardBorderStyle}"
                                                            Margin="0,0,0,8"
                                                            Padding="12,10"
                                                            Cursor="Hand">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/> <!-- Date metadata -->
                                                                <RowDefinition Height="6"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/> <!-- Notes area -->
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Task name inline edit -->
                                                            <TextBox Grid.Column="0"
                                                                     Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                                     res:FocusBehavior.IsFocused="{Binding IsFocused, Mode=TwoWay}"
                                                                     Style="{StaticResource SeamlessTextBox}"
                                                                     FontFamily="{StaticResource MainFont}"
                                                                     FontSize="13" FontWeight="Medium"
                                                                     Foreground="{DynamicResource TextPrimary}"
                                                                     TextWrapping="Wrap"
                                                                     AcceptsReturn="False"
                                                                     VerticalAlignment="Top"
                                                                     dd:DragDrop.DragSourceIgnore="True"/>

                                                            <!-- Delete task -->
                                                            <Button Grid.Column="1"
                                                                    Style="{StaticResource DangerIconButton}"
                                                                    Padding="4"
                                                                    VerticalAlignment="Top"
                                                                    Command="{Binding DeleteCommand}"
                                                                    ToolTip="Delete task">
                                                                <Path Data="M0 0 L6 6 M6 0 L0 6"
                                                                      Stroke="{DynamicResource TextTertiary}"
                                                                      StrokeThickness="1.2"
                                                                      Stretch="Uniform" Width="6" Height="6"/>
                                                            </Button>

                                                            <!-- Date metadata (small) -->
                                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                                                       Text="{Binding Model.TaskDate, StringFormat={}{0:MMM d, yyyy}}"
                                                                       FontFamily="{StaticResource MainFont}"
                                                                       FontSize="10" FontWeight="Medium"
                                                                       Foreground="{DynamicResource TextTertiary}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,3,0,0"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <!-- Time metadata & Actions row -->
                                                            <Grid Grid.Row="3" Grid.ColumnSpan="2" VerticalAlignment="Center">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <Path Data="M12,2C6.5,2,2,6.5,2,12s4.5,10,10,10s10-4.5,10-10S17.5,2,12,2z M12,20c-4.4,0-8-3.6-8-8s3.6-8,8-8s8,3.6,8,8S16.4,20,12,20z M12.5,7H11v6l5.2,3.1l0.8-1.2L12.5,12V7z"
                                                                          Fill="{DynamicResource TextTertiary}"
                                                                          Stretch="Uniform"
                                                                          Width="11" Height="11"
                                                                          VerticalAlignment="Center"
                                                                          Margin="0,0,5,0"/>
                                                                    <TextBox Text="{Binding EstimatedTime, UpdateSourceTrigger=LostFocus}"
                                                                             Style="{StaticResource SeamlessTextBox}"
                                                                             FontFamily="{StaticResource MainFont}"
                                                                             FontSize="11"
                                                                             Foreground="{DynamicResource TextTertiary}"
                                                                             Width="110"
                                                                             VerticalAlignment="Center"
                                                                             dd:DragDrop.DragSourceIgnore="True"/>
                                                                </StackPanel>

                                                                <!-- Notes toggle button -->
                                                                <Button Grid.Column="2"
                                                                        Style="{StaticResource IconButton}"
                                                                        Padding="4"
                                                                        Command="{Binding ToggleNotesCommand}"
                                                                        ToolTip="Toggle notes">
                                                                    <Path Data="M14,10H2v2h12V10z M14,6H2v2h12V6z M2,14h8v-2H2V14z"
                                                                          Fill="{DynamicResource TextTertiary}"
                                                                          Stretch="Uniform" Width="12" Height="12"/>
                                                                </Button>
                                                            </Grid>

                                                            <!-- Notes inline edit -->
                                                            <Border Grid.Row="4" Grid.ColumnSpan="2"
                                                                    Margin="0,8,0,0"
                                                                    Visibility="{Binding IsNotesExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource NoteTextBox}" 
                                                                         MinHeight="40" MaxHeight="120"
                                                                         AcceptsReturn="True"
                                                                         TextWrapping="Wrap"
                                                                         FontSize="11"
                                                                         VerticalScrollBarVisibility="Auto"
                                                                         Foreground="{DynamicResource TextSecondary}"
                                                                         dd:DragDrop.DragSourceIgnore="True"
                                                                         Padding="8,6"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Task card hover effect -->
                                                    <DataTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="TaskCard" Property="Effect" Value="{StaticResource CardShadowHover}"/>
                                                            <Setter TargetName="TaskCard" Property="BorderBrush" Value="{DynamicResource BorderColorHover}"/>
                                                        </Trigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </ScrollViewer>

                                <!-- â”€â”€ Column Footer (Add Task) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
                                <Border Grid.Row="2" Padding="10,6,10,10">
                                    <Button Content="+ Add Task"
                                            Style="{StaticResource SecondaryButton}"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding AddTaskCommand}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Column hover: enhance shadow -->
                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ColumnBorder" Property="Effect" Value="{StaticResource CardShadow}"/>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>
</UserControl>

