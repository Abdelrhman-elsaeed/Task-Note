<UserControl x:Class="TaskNote.Views.TimerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TaskNote.Views"
             xmlns:vm="clr-namespace:TaskNote.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="228">

    <Border BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="0,1,0,1"
            Padding="4,14,4,14"
            Margin="0,6,0,6">
        <StackPanel>

            <!-- Section label -->
            <TextBlock Text="FOCUS TIMER"
                       FontFamily="{StaticResource MainFont}"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextTertiary}"
                       Margin="0,0,0,10"/>

            <!-- Large countdown display -->
            <TextBlock Text="{Binding TimeString}"
                       FontFamily="{StaticResource MainFont}"
                       FontSize="38" FontWeight="Light"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>

            <!-- Progress bar (rounded, amber gradient) -->
            <Grid Margin="0,0,0,14">
                <ProgressBar Value="{Binding Progress}"
                             Height="4"
                             BorderThickness="0"
                             Background="{DynamicResource BorderColor}"
                             Foreground="{DynamicResource AccentColor}">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid>
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="2" Height="4"/>
                                <Border x:Name="PART_Track" CornerRadius="2" Height="4" Background="Transparent"/>
                                <Border x:Name="PART_Indicator"
                                        CornerRadius="2" Height="4"
                                        HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#D97706" Offset="0"/>
                                            <GradientStop Color="#F59E0B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </Grid>

            <!-- Controls: play / pause / stop -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Start button (when not running) -->
                <Button Grid.Column="1"
                        Width="42" Height="42" Margin="4,0"
                        Style="{StaticResource TimerPlayButton}"
                        Command="{Binding StartTimerCommand}"
                        Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}">
                    <Path Data="M 10 8 L 26 18 L 10 28 Z"
                          Fill="White" Stretch="Fill" Width="11" Height="12"
                          HorizontalAlignment="Center" Margin="2,0,0,0"/>
                </Button>

                <!-- Pause/Resume button (when running) -->
                <Button Grid.Column="1"
                        Width="42" Height="42" Margin="4,0"
                        Style="{StaticResource TimerCircleButton}"
                        Command="{Binding TogglePauseCommand}"
                        Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Width="14" Height="14">
                        <!-- Pause icon -->
                        <Path Data="M10 8 H13 V24 H10 Z M18 8 H21 V24 H18 Z"
                              Fill="{DynamicResource AccentColor}" Stretch="Fill"
                              Visibility="{Binding IsPaused, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}"/>
                        <!-- Resume icon -->
                        <Path Data="M 10 8 L 26 18 L 10 28 Z"
                              Fill="{DynamicResource AccentColor}" Stretch="Fill"
                              Visibility="{Binding IsPaused, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </Button>

                <!-- Stop button -->
                <Button Grid.Column="2"
                        Width="42" Height="42" Margin="4,0"
                        Style="{StaticResource TimerCircleButton}"
                        Command="{Binding StopTimerCommand}"
                        IsEnabled="{Binding IsRunning}">
                    <Rectangle Width="11" Height="11"
                               Fill="{DynamicResource TextSecondary}"
                               RadiusX="2" RadiusY="2"/>
                </Button>
            </Grid>

            <!-- Preset duration pills (only when timer is stopped) -->
            <StackPanel Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">

                    <Button Content="15m" Margin="3,0"
                            Command="{Binding QuickSetDurationCommand}"
                            CommandParameter="{StaticResource Int15}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TimerPresetButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMinutes}" Value="15">
                                        <Setter Property="Background"  Value="{DynamicResource AccentColor}"/>
                                        <Setter Property="Foreground"  Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                        <Setter Property="FontWeight"  Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="25m" Margin="3,0"
                            Command="{Binding QuickSetDurationCommand}"
                            CommandParameter="{StaticResource Int25}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TimerPresetButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMinutes}" Value="25">
                                        <Setter Property="Background"  Value="{DynamicResource AccentColor}"/>
                                        <Setter Property="Foreground"  Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                        <Setter Property="FontWeight"  Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="45m" Margin="3,0"
                            Command="{Binding QuickSetDurationCommand}"
                            CommandParameter="{StaticResource Int45}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TimerPresetButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMinutes}" Value="45">
                                        <Setter Property="Background"  Value="{DynamicResource AccentColor}"/>
                                        <Setter Property="Foreground"  Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                        <Setter Property="FontWeight"  Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Today's focus stat -->
            <TextBlock Text="{Binding TodayFocusedText}"
                       FontFamily="{StaticResource MainFont}"
                       FontSize="11"
                       Foreground="{DynamicResource TextTertiary}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>

