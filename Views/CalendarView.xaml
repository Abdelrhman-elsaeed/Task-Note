<UserControl x:Class="TaskNote.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:res="clr-namespace:TaskNote.Resources"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    
    <UserControl.Resources>
        <res:ZeroCountToVisibilityConverter x:Key="ZeroCountToVisibilityConverter" />
        <res:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <Style x:Key="WeekdayLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Inter, Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </UserControl.Resources>
    
    <Border Background="{DynamicResource AppBackground}" Padding="0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{StaticResource MinimalScrollViewer}">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="24,40,24,40">
                <Grid.ColumnDefinitions>
                    <!-- Left: Calendar Area -->
                    <ColumnDefinition Width="680" />
                    <!-- Right: Day Details Panel -->
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <!-- ==============================================
                     1. CALENDAR AREA
                     ============================================== -->
                <Border Grid.Column="0" Margin="0,0,32,0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="16" Padding="24" Effect="{StaticResource SubtleShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <!-- Month Switcher Header -->
                            <RowDefinition Height="Auto" /> <!-- Weekday Labels -->
                            <RowDefinition Height="*" />    <!-- Calendar Days Grid -->
                        </Grid.RowDefinitions>

                        <!-- Month Switcher Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" 
                                    Style="{DynamicResource SecondaryButton}"
                                    Command="{Binding PreviousMonthCommand}"
                                    ToolTip="Previous Month"
                                    Padding="10,8">
                                <Path Data="M15,19L16.41,17.59L10.83,12L16.41,6.41L15,5L8,12L15,19Z"
                                      Fill="{DynamicResource TextSecondary}"
                                      Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                            
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding CurrentMonthYearName}"
                                       FontFamily="Segoe UI Variable Display, Inter, Segoe UI"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            
                            <Button Grid.Column="2" 
                                    Style="{DynamicResource SecondaryButton}"
                                    Command="{Binding NextMonthCommand}"
                                    ToolTip="Next Month"
                                    Padding="10,8">
                                <Path Data="M8.59,16.59L10,18L16,12L10,6L8.59,7.41L13.17,12L8.59,16.59Z"
                                      Fill="{DynamicResource TextSecondary}"
                                      Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                        </Grid>

                        <!-- Weekday Labels Header -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="SUN" Style="{StaticResource WeekdayLabelStyle}"/>
                            <TextBlock Grid.Column="1" Text="MON" Style="{StaticResource WeekdayLabelStyle}"/>
                            <TextBlock Grid.Column="2" Text="TUE" Style="{StaticResource WeekdayLabelStyle}"/>
                            <TextBlock Grid.Column="3" Text="WED" Style="{StaticResource WeekdayLabelStyle}"/>
                            <TextBlock Grid.Column="4" Text="THU" Style="{StaticResource WeekdayLabelStyle}"/>
                            <TextBlock Grid.Column="5" Text="FRI" Style="{StaticResource WeekdayLabelStyle}"/>
                            <TextBlock Grid.Column="6" Text="SAT" Style="{StaticResource WeekdayLabelStyle}"/>
                        </Grid>

                        <!-- Calendar Days Grid -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding CalendarDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7" Rows="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="0" Background="Transparent" BorderThickness="0"
                                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                            Margin="4">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="CardBorder"
                                                        Background="{DynamicResource AppBackground}"
                                                        BorderBrush="{DynamicResource BorderColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="10"
                                                        Height="92"
                                                        Width="92"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <!-- Row 0: Day Number & Today dot -->
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <TextBlock Grid.Column="0" x:Name="DayNumText"
                                                                       Text="{Binding DayNumber}"
                                                                       FontFamily="Segoe UI Variable Display, Inter, Segoe UI"
                                                                       FontSize="14" FontWeight="Bold"
                                                                       Foreground="{DynamicResource TextPrimary}"
                                                                       HorizontalAlignment="Left"/>
                                                            
                                                            <Ellipse Grid.Column="1" x:Name="TodayDot"
                                                                     Width="6" Height="6"
                                                                     Fill="{DynamicResource AccentColor}"
                                                                     HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                     Margin="4,0,0,0"
                                                                     Visibility="Collapsed"/>
                                                        </Grid>

                                                        <!-- Row 1: Study Time (Minutes) -->
                                                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,0">
                                                            <Border x:Name="StudyBadge"
                                                                    Background="{DynamicResource AccentSubtle}"
                                                                    BorderBrush="{DynamicResource AccentColor}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4"
                                                                    Padding="6,2"
                                                                    Visibility="Collapsed">
                                                                <TextBlock Text="{Binding MinutesStudied, StringFormat={}{0}m}"
                                                                           FontFamily="Segoe UI Variable Text, Inter, Segoe UI"
                                                                           FontSize="10" FontWeight="Bold"
                                                                           Foreground="{DynamicResource AccentColor}"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <!-- Row 2: Completed Tasks Count -->
                                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,2">
                                                            <Border x:Name="TasksBadge"
                                                                    Background="#EBF6F0"
                                                                    BorderBrush="{DynamicResource SuccessColor}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4"
                                                                    Padding="6,2"
                                                                    Visibility="Collapsed">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="✓"
                                                                               FontFamily="Segoe UI Variable Text, Inter, Segoe UI"
                                                                               FontSize="10" FontWeight="Bold"
                                                                               Foreground="{DynamicResource SuccessColor}"
                                                                               Margin="0,0,4,0"/>
                                                                    <TextBlock Text="{Binding CompletedTasksCount}"
                                                                               FontFamily="Segoe UI Variable Text, Inter, Segoe UI"
                                                                               FontSize="10" FontWeight="Bold"
                                                                               Foreground="{DynamicResource SuccessColor}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <!-- Not in Current Month -->
                                                    <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                        <Setter TargetName="CardBorder" Property="Background" Value="Transparent" />
                                                        <Setter TargetName="CardBorder" Property="Opacity" Value="0.3" />
                                                        <Setter TargetName="CardBorder" Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                    
                                                    <!-- Is Today -->
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter TargetName="TodayDot" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    
                                                    <!-- Has Study Time -->
                                                    <DataTrigger Binding="{Binding HasStudyTime}" Value="True">
                                                        <Setter TargetName="StudyBadge" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>

                                                    <!-- Has Completed Tasks -->
                                                    <DataTrigger Binding="{Binding HasCompletedTasks}" Value="True">
                                                        <Setter TargetName="TasksBadge" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>

                                                    <!-- Is Selected -->
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}" />
                                                        <Setter TargetName="CardBorder" Property="BorderThickness" Value="2" />
                                                        <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource AccentSubtle}" />
                                                    </DataTrigger>

                                                    <!-- Hover state -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                        <Setter TargetName="CardBorder" Property="Effect" Value="{StaticResource SubtleShadow}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- ==============================================
                     2. DAY DETAILS PANEL
                     ============================================== -->
                <Border Grid.Column="1" Background="{DynamicResource CardBackground}" 
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" 
                        CornerRadius="16" Padding="24" Effect="{StaticResource SubtleShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <!-- Selected Date Header -->
                            <RowDefinition Height="Auto" /> <!-- Study Time Card -->
                            <RowDefinition Height="Auto" /> <!-- Section Label -->
                            <RowDefinition Height="*" />    <!-- Completed Tasks List -->
                        </Grid.RowDefinitions>

                        <!-- Selected Date Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,24">
                            <TextBlock Text="DAY DETAILS" 
                                       FontFamily="Segoe UI Variable Display, Inter, Segoe UI"
                                       FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextTertiary}" />
                            <TextBlock Text="{Binding SelectedDate, StringFormat={}{0:dddd, MMMM d, yyyy}}" 
                                       FontFamily="Segoe UI Variable Display, Inter, Segoe UI"
                                       FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" 
                                       Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Study Time Card -->
                        <Border Grid.Row="1" Background="{DynamicResource AppBackground}" 
                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" 
                                CornerRadius="12" Padding="20" Margin="0,0,0,32">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- Clock/Timer Icon -->
                                <Path Grid.Column="0" Data="M12,2A10,10,0,1,0,22,12,10,10,0,0,0,12,2Zm0,18a8,8,0,1,1,8-8A8,8,0,0,1,12,20ZM12.5,7H11v6l5.2,3.1.8-1.2-4.5-2.7Z"
                                      Fill="{DynamicResource AccentColor}" Stretch="Uniform" Width="32" Height="32" 
                                      VerticalAlignment="Center" Margin="0,0,16,0" />
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Total Study Time" 
                                               FontFamily="Segoe UI Variable Text, Inter, Segoe UI"
                                               FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding MinutesStudied}" 
                                                   FontFamily="Segoe UI Variable Display, Inter, Segoe UI"
                                                   FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text=" minutes" 
                                                   FontFamily="Segoe UI Variable Text, Inter, Segoe UI"
                                                   FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}" 
                                                   VerticalAlignment="Bottom" Margin="4,0,0,6" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Section Label -->
                        <TextBlock Grid.Row="2" Text="COMPLETED TASKS" 
                                   FontFamily="Segoe UI Variable Display, Inter, Segoe UI"
                                   FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextTertiary}" 
                                   Margin="0,0,0,12" />

                        <!-- Completed Tasks List -->
                        <Grid Grid.Row="3">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                          HorizontalScrollBarVisibility="Disabled"
                                          Style="{StaticResource MinimalScrollViewer}">
                                <ItemsControl ItemsSource="{Binding CompletedTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource AppBackground}" 
                                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" 
                                                    CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Checkmark Icon -->
                                                    <Border Grid.Column="0" Background="#EBF6F0" CornerRadius="4" Padding="4" Margin="0,0,12,0" VerticalAlignment="Center">
                                                        <Path Data="M9,16.2L4.8,12l-1.4,1.4L9,19 21,7l-1.4-1.4L9,16.2z" 
                                                              Fill="{DynamicResource SuccessColor}" Stretch="Uniform" Width="14" Height="14" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                                               FontFamily="Segoe UI Variable Text, Inter, Segoe UI"
                                                               FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" 
                                                               VerticalAlignment="Center" TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <!-- Placeholder if no completed tasks -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding CompletedTasks.Count, Converter={StaticResource ZeroCountToVisibilityConverter}}">
                                <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"
                                      Fill="{DynamicResource BorderColor}" Stretch="Uniform" Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                <TextBlock Text="No tasks completed on this day." 
                                           FontFamily="Segoe UI Variable Text, Inter, Segoe UI"
                                           FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextTertiary}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
